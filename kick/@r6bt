-- Kick settings (customizable)
local kickEnabled = false
local kickAtTime = 2   -- default value

local function clearBaseTimerESP()
    for plot, bb in pairs(ESPs.BaseTimer.Data) do
        if bb then pcall(function() bb:Destroy() end) end
    end
    ESPs.BaseTimer.Data = {}
    myPlot = nil
    hasKicked = false
end

-- Find your plot
local function getMyPlot()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end

    local lowerName = playerName:lower()
    local lowerDisplay = displayName:lower()

    for _, plot in pairs(plotsFolder:GetChildren()) do
        local plotNameLower = plot.Name:lower()
        if plot.Name == playerName or plot.Name == displayName or
           plotNameLower:find(lowerName) or plotNameLower:find(lowerDisplay) then
            return plot
        end

        local ownerValue = plot:FindFirstChild("Owner") 
                        or plot:FindFirstChild("Player") 
                        or plot:FindFirstChild("OwnerName")

        if ownerValue then
            if ownerValue:IsA("StringValue") then
                local val = ownerValue.Value:lower()
                if val == lowerName or val == lowerDisplay then
                    return plot
                end
            elseif ownerValue:IsA("ObjectValue") and ownerValue.Value then
                if ownerValue.Value.Name == playerName or ownerValue.Value.Name == displayName then
                    return plot
                end
            end
        end

        for _, descendant in pairs(plot:GetDescendants()) do
            if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
                local txt = descendant.Text:lower()
                if txt:find(lowerName) or txt:find(lowerDisplay) then
                    return plot
                end
            end
        end
    end
    return nil
end

-- Check if timer has reached the custom kick time
local function shouldKick(timerText)
    if not timerText or timerText == "" then return false end
    local clean = timerText:gsub("[^%d:]", "")
    if clean == tostring(kickAtTime) or clean == ("0" .. kickAtTime) or clean:match(":" .. string.format("%02d", kickAtTime) .. "$") then
        return true
    end
    local num = tonumber(clean:match("%d+"))
    if num and num <= kickAtTime then
        return true
    end
    return false
end

