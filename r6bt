    if num then
        kickAtTime = math.max(0, num)  -- prevent negative
        KickTextBox.Text = tostring(kickAtTime)
    else
        KickTextBox.Text = tostring(kickAtTime)  -- reset if invalid
    end
end)

-- ==================== Main Logic ====================
local function updateBaseTimerESP()
    if not ESPs.BaseTimer.Enabled then return end

    local now = tick()
    if now - lastScan > 0.5 then
        myPlot = getMyPlot()
        lastScan = now
    end

    local plot = myPlot
    if not plot then return end

    local purchases = plot:FindFirstChild("Purchases")
    local block = purchases and purchases:FindFirstChild("PlotBlock")
    local main = block and block:FindFirstChild("Main")

    if main then
        local timerGui = main:FindFirstChild("BillboardGui")
        local timer = timerGui and timerGui:FindFirstChild("RemainingTime")

        if timer then
            local timerText = timer.Text

            -- Auto-kick (only if enabled)
            if kickEnabled and shouldKick(timerText) and not hasKicked then
                hasKicked = true
                print("[ESP] Timer reached " .. kickAtTime .. " → Kicking player...")
                LocalPlayer:Kick("Kicked By VCF - .gg/98pwBypBE4")
                return
            end

            -- Create/Update ESP
            if not ESPs.BaseTimer.Data[plot] then
                local bb = Instance.new("BillboardGui")
                bb.Adornee = main
                bb.Size = UDim2.new(0, 80, 0, 30)
                bb.StudsOffset = Vector3.new(0, 5, 0)
                bb.AlwaysOnTop = true
                bb.Parent = plot

                local lbl = Instance.new("TextLabel", bb)
                lbl.Size = UDim2.new(1,0,1,0)
                lbl.BackgroundTransparency = 1
                lbl.TextColor3 = Color3.fromRGB(255,255,100)
                lbl.TextStrokeTransparency = 0
                lbl.Font = Enum.Font.GothamBold
                lbl.TextSize = 16

                ESPs.BaseTimer.Data[plot] = bb
            end

            if ESPs.BaseTimer.Data[plot] and ESPs.BaseTimer.Data[plot]:FindFirstChild("TextLabel") then
                ESPs.BaseTimer.Data[plot].TextLabel.Text = timerText
            end
        end
    end
end

RunService.Heartbeat:Connect(function()
    if ESPs.BaseTimer.Enabled then
        updateBaseTimerESP()
    end
end)

